{
  "index_patterns": ["recon-lookup-*"],
  "priority": 200,
  "_meta": {
    "description": "Field mappings for recon-lookup-* indices. Pins documented ECS-standard and recon-specific fields to types that match the JSON shape so Kibana visualizations do not drift on first-write surprises.",
    "managed_by": "recon"
  },
  "template": {
    "settings": {
      "index": {
        "number_of_shards": 1,
        "number_of_replicas": 1,
        "default_pipeline": "recon-lookup"
      }
    },
    "mappings": {
      "properties": {
        "@timestamp": { "type": "date" },
        "event": {
          "properties": {
            "kind": { "type": "keyword" },
            "category": { "type": "keyword" },
            "type": { "type": "keyword" },
            "dataset": { "type": "keyword" },
            "module": { "type": "keyword" }
          }
        },
        "host": {
          "properties": {
            "domain": { "type": "keyword" }
          }
        },
        "recon": {
          "properties": {
            "display_name": { "type": "keyword" },
            "provider": { "type": "keyword" },
            "confidence": { "type": "keyword" },
            "auth_type": { "type": "keyword" },
            "cloud_instance": { "type": "keyword" },
            "services": { "type": "keyword" },
            "slugs": { "type": "keyword" },
            "insights": { "type": "text" },
            "email": {
              "properties": {
                "dmarc_policy": { "type": "keyword" },
                "security_score": { "type": "long" },
                "primary_provider": { "type": "keyword" }
              }
            },
            "fusion": {
              "properties": {
                "posteriors": {
                  "type": "nested",
                  "properties": {
                    "name": { "type": "keyword" },
                    "posterior": { "type": "float" },
                    "interval_low": { "type": "float" },
                    "interval_high": { "type": "float" },
                    "sparse": { "type": "boolean" }
                  }
                }
              }
            },
            "evidence_conflicts": {
              "type": "nested",
              "properties": {
                "field": { "type": "keyword" },
                "candidates": {
                  "type": "nested",
                  "properties": {
                    "value": { "type": "keyword", "ignore_above": 1024 },
                    "source": { "type": "keyword" },
                    "confidence": { "type": "keyword" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
